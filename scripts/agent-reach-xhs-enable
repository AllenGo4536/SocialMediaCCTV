#!/usr/bin/env sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
LOG_DIR="$HOME/.agent-reach/logs"

mkdir -p "$LOG_DIR"

"$ROOT_DIR/scripts/agent-reach-xhs-install"
nohup "$ROOT_DIR/scripts/agent-reach-xhs-start" > "$LOG_DIR/xiaohongshu-mcp.log" 2>&1 &
sleep 3

if ! mcporter config list 2>/dev/null | grep -q xiaohongshu; then
  mcporter config add xiaohongshu http://localhost:18060/mcp
fi

mcporter list xiaohongshu --json
