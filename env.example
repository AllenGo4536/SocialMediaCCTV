# Supabase Configuration
# Get these from your Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Apify Configuration
# Get this from Apify Console -> Settings -> Integrations
APIFY_API_TOKEN=your-apify-api-token

# ViraX Internal Security
# Choose a secret password for Admin operations (Adding/Deleting profiles)
# You will be prompted for this in the UI
VIRAX_SECRET_KEY=dev-secret-key

# Base URL for Webhooks
# IMPORTANT: For Apify to send data back to your local machine, you need a public URL (e.g. via ngrok)
# If just testing UI without real data updates, localhost is fine.
# NEXT_PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Cron Security (Optional for local)
CRON_SECRET=
